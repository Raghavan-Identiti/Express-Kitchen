---
interface Props {
  title?: string;
  description?: string;
  robots?: string;
}

const {
  title = "Online Assembled Cabinets - Express Kitchens",
  description = "The kitchen you've always pictured, without the stress, the wait, or the price you were dreading.",
  robots = "noindex, nofollow",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link
      rel="canonical"
      href={Astro.url.pathname === "/"
        ? "https://expresskitchens.com"
        : `https://expresskitchens.com${Astro.url.pathname}`}
    />
  </head>
  <body>
    <slot />
  </body>
</html>
