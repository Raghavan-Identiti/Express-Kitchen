---
// src/components/Counter.astro
const stats = [
  {
    value: "108",
    label: "Years Making<br/>Kitchens Right",
    target: 108,
    suffix: "",
  },
  {
    value: "50,000+",
    label: "All-Plywood Cabinets,<br/>Ready to Ship",
    target: 50000,
    suffix: "+",
  },
  {
    value: "5,000+",
    label: "Happy Customer<br/>Reviews",
    target: 5000,
    suffix: "+",
  },
  { value: "100K+", label: "Kitchens<br/>Designed", target: 100, suffix: "K+" },
  { value: "10", label: "Showrooms<br/>to Visit", target: 10, suffix: "" },
  { value: "A+", label: "BBB<br/>Rating", target: 0, suffix: "A+" },
];
---

<section class="ek-counter-section">
  <div class="container">
    <div class="ek-counter-grid">
      {
        stats.map((stat) => (
          <div class="ek-counter-item">
            <div class="ek-counter-content">
              <h2
                class="ek-counter-value"
                data-target={stat.target}
                data-suffix={stat.suffix}
                data-final={stat.value}
              >
                {stat.value}
              </h2>
              <p class="ek-counter-label" set:html={stat.label} />
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .ek-counter-section {
    background-color: color-mix(in srgb, var(--ek-soft-cream), transparent 25%);
    padding: 60px 0;
    overflow: hidden;
  }

  .ek-counter-grid {
    display: grid;
    grid-template-columns: 0.8fr 1.1fr 1fr 1fr 0.7fr 0.7fr;
    width: 100%;
    gap: 0;
  }

  .ek-counter-item {
    padding: 0 15px;
    position: relative;
    display: flex;
    justify-content: center;
  }

  .ek-counter-item:not(:last-child)::after {
    content: "";
    position: absolute;
    top: 15%;
    right: 0;
    width: 1px;
    height: 70%;
    background: linear-gradient(
      to bottom,
      rgba(237, 28, 36, 0) 0%,
      rgba(237, 28, 36, 0.4) 50%,
      rgba(237, 28, 36, 0) 100%
    );
  }

  .ek-counter-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    height: 100%;
    padding: 10px 0;
    min-width: 0;
  }

  .ek-counter-value {
    font-family: var(--ek-primary-font);
    color: var(--ek-primary-red);
    font-size: 50px;
    font-weight: 800;
    line-height: 100%;
    margin-bottom: 12px;
    letter-spacing: 0%;
    text-align: left;
    /* Key fixes: stable width + no digit-width jitter */
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
    /* Reserve space based on final value so layout never shifts */
    min-width: max-content;
  }

  .ek-counter-label {
    font-family: var(--ek-primary-font);
    color: var(--ek-gray-tint-25);
    font-size: 16px;
    font-weight: 500;
    line-height: 120%;
    letter-spacing: 0%;
    margin: 10px 0;
    text-align: left;
  }

  @media (max-width: 1200px) {
    .ek-counter-item {
      padding: 0 20px;
    }
  }

  @media (max-width: 991px) {
    .ek-counter-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 30px 0;
    }
    .ek-counter-item:nth-child(3n)::after {
      display: none;
    }
    .ek-counter-item {
      border-bottom: 1px solid rgba(242, 8, 25, 0.1);
      padding-bottom: 20px;
    }
    .ek-counter-item:nth-last-child(-n + 3) {
      border-bottom: none;
    }
    .ek-counter-value {
      font-size: 36px;
    }
    .ek-counter-label {
      font-size: 14px;
    }
    .ek-counter-section {
      padding: 40px 0;
    }
  }

  @media (max-width: 767px) {
    .ek-counter-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .ek-counter-item:nth-child(3n)::after {
      display: block;
    }
    .ek-counter-item:nth-child(2n)::after {
      display: none;
    }
    .ek-counter-item:nth-last-child(3) {
      border-bottom: 1px solid rgba(242, 8, 25, 0.1);
    }
    .col:nth-last-child(2) {
      border-bottom: 1px solid rgba(242, 8, 25, 0.1);
    }
    .ek-counter-item {
      padding: 0px;
    }
  }
</style>

<script>
  const formatNumber = (num: number): string => {
    return num.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ",");
  };

  const animateCounters = () => {
    const counters =
      document.querySelectorAll<HTMLElement>(".ek-counter-value");

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;

          const el = entry.target as HTMLElement;
          const target = parseInt(el.getAttribute("data-target") || "0", 10);
          const suffix = el.getAttribute("data-suffix") || "";
          const final = el.getAttribute("data-final") || "";

          observer.unobserve(el);

          // Static values (A+) or zero-target — just show final, no animation
          if (target === 0) {
            el.textContent = final;
            return;
          }

          let current = 0;
          const steps = 40;
          const increment = target / steps;
          const stepTime = 1500 / steps;

          const timer = setInterval(() => {
            current += increment;
            if (current >= target) {
              // Snap to the exact final display value (e.g. "100K+", "50,000+")
              el.textContent = final;
              clearInterval(timer);
            } else {
              el.textContent = formatNumber(Math.ceil(current)) + suffix;
            }
          }, stepTime);
        });
      },
      { threshold: 0.5 },
    );

    counters.forEach((counter) => observer.observe(counter));
  };

  document.addEventListener("DOMContentLoaded", animateCounters);
</script>
