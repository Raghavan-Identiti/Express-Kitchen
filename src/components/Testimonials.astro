---
import { Image } from "astro:assets";
import testimonial_arrow_icon from "../assets/images/testimonial_arrow_icon.svg";

const testimonials = [
  {
    image:
      "https://cdn11.bigcommerce.com/s-dsdbflh9ev/images/stencil/original/image-manager/review-1-elizabeth.png?t=1774706604",
    name: "Elizabeth Masalin",
    title: "Exactly what I wanted!",
    text: `"I am so very pleased with Express Kitchen!! I can't say enough great things about Susan!! She is so kind and so very knowledgeable..."`,
  },
  {
    image:
      "https://cdn11.bigcommerce.com/s-dsdbflh9ev/images/stencil/original/image-manager/review-2-lauren.png?t=1774706606",
    name: "Lauren Fuller",
    title: "Collaboration was amazing",
    text: `"I had such a great experience. This being the first time I've ever done a kitchen remodel I appreciated Deb Wolak's ability..."`,
  },
  {
    image:
      "https://cdn11.bigcommerce.com/s-dsdbflh9ev/images/stencil/original/image-manager/review-3-uncle-brad.png?t=1774706608",
    name: "Uncle Brad",
    title: "TOP-NOTCH Customer Service",
    text: `"This was a great buying experience. Sharmin and Raffi are to be commended for their TOP-NOTCH customer service..."`,
  },
  {
    image:
      "https://cdn11.bigcommerce.com/s-dsdbflh9ev/images/stencil/original/image-manager/review-4-maria.png?t=1774706611",
    name: "Maria Santos",
    title: "Dream kitchen delivered!",
    text: `"The whole process from design to delivery was seamless. The team made it so easy and stress-free. Absolutely love the result..."`,
  },
  {
    image:
      "https://cdn11.bigcommerce.com/s-dsdbflh9ev/images/stencil/original/image-manager/review-5-james.png?t=1774706614",
    name: "James Thornton",
    title: "Worth every penny",
    text: `"Skeptical about ordering cabinets online, but Express Kitchens exceeded every expectation. Quality is truly outstanding..."`,
  },
];
// src/components/Testimonials.astro
---

<section class="ek-testimonial-section">
  <div class="ek-testimonial-container">
    <!-- Header -->
    <div class="ek-testimonial-header">
      <span class="ek-testimonial-tag">REAL KITCHENS. REAL FAMILIES.</span>
      <h2>Don't <span>take our word</span> for it.</h2>
      <p>
        5,000+ verified reviews across Google, BBB, and Houzz · Rated A+ by the
        Better Business Bureau
      </p>
    </div>

    <!-- Carousel -->
    <div class="ek-testimonial-carousel">
      <!-- Desktop arrows sit outside viewport as flex siblings -->
      <button class="ek-carousel-control prev desktop-arrow"
        ><Image src={testimonial_arrow_icon} alt="Previous" /></button
      >

      <!-- Inner wrapper: on mobile, arrows are absolutely positioned over this -->
      <div class="ek-carousel-inner">
        <!-- Mobile-only arrows inside the inner wrapper -->
        <button class="ek-carousel-control prev mobile-arrow"
          ><Image src={testimonial_arrow_icon} alt="Previous" /></button
        >
        <button class="ek-carousel-control next mobile-arrow"
          ><Image src={testimonial_arrow_icon} alt="Next" /></button
        >

        <div class="ek-carousel-viewport">
          <div class="ek-carousel-track">
            {
              testimonials.map((t) => (
                <div class="ek-testimonial-card">
                  <Image
                    src={t.image}
                    alt="Testimonial background"
                    class="ek-testimonial-image"
                    inferSize={true}
                  />
                  <div class="ek-card-content">
                    <h4>{t.name}</h4>
                    <div class="ek-stars">★★★★★</div>
                    <h5>{t.title}</h5>
                    <p>{t.text}</p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>

      <button class="ek-carousel-control next desktop-arrow"
        ><Image src={testimonial_arrow_icon} alt="Next" /></button
      >
    </div>
  </div>
</section>

<style>
  /* Testimonials Section */
  .ek-testimonial-section {
    background: var(--ek-gray-shade-premium);
    background-image: url("../assets/images/testimonial_bg_image.webp");
    background-size: cover;
    background-position: center;
    padding: 100px 20px;
    color: var(--ek-white);
    text-align: center;
    position: relative;
    overflow: hidden;
    font-family: var(--ek-primary-font);
  }

  /* Header */
  .ek-testimonial-header h2 {
    font-size: 35px;
    font-weight: 700;
    margin: 15px 0;
    color: var(--ek-white);
  }

  .ek-testimonial-header h2 span {
    color: var(--ek-primary-red);
  }

  .ek-testimonial-header p {
    color: var(--ek-white);
    font-size: 18px;
    font-weight: 400;
    line-height: 100%;
    letter-spacing: 0px;
  }

  .ek-testimonial-tag {
    display: inline-block;
    background: var(--ek-red-tint-60);
    color: var(--ek-black);
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 13px;
    font-weight: 500;
    line-height: 100%;
    letter-spacing: 0px;
  }

  /* Carousel */
  .ek-testimonial-carousel {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 50px;
    position: relative;
    max-width: 1320px;
    margin-left: auto;
    margin-right: auto;
  }

  /* Inner wrapper — only meaningful on mobile */
  .ek-carousel-inner {
    display: contents; /* transparent on desktop */
  }

  /* Hide mobile arrows on desktop */
  .mobile-arrow {
    display: none;
  }

  .ek-carousel-viewport {
    width: 1190px;
    max-width: 92%;
    display: flex;
    justify-content: flex-start;
    overflow: hidden;
  }

  .ek-carousel-track {
    display: flex;
    gap: 25px;
    transition: transform 0.4s ease;
  }

  /* Cards */
  .ek-testimonial-card {
    width: 380px;
    height: 390px;
    background: var(--ek-white);
    border-radius: 14px;
    overflow: hidden;
    color: var(--ek-black);
    text-align: left;
    flex-shrink: 0;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
  }

  .ek-testimonial-card img {
    width: 100%;
    height: 180px;
    object-fit: cover;
  }

  .ek-card-content {
    padding: 18px;
  }

  .ek-card-content h4 {
    margin: 0;
    font-size: 15px;
    font-weight: 500;
    line-height: 150%;
    letter-spacing: 0%;
  }

  .ek-stars {
    color: #ffc107;
    margin: 5px 0;
  }

  .ek-card-content h5 {
    color: var(--ek-primary-red);
    font-size: 16px;
    margin: 6px 0;
    font-weight: 500;
    line-height: 150%;
    letter-spacing: 0%;
  }

  .ek-card-content p {
    font-size: 14px;
    color: var(--ek-gray-tint-25);
    font-weight: 500;
    line-height: 150%;
    letter-spacing: 0%;
  }

  /* Arrows — desktop */
  .ek-carousel-control {
    background: none;
    border: none;
    color: var(--ek-white);
    font-size: 28px;
    cursor: pointer;
    padding: 20px;
    flex-shrink: 0;
  }

  .ek-carousel-control.next img {
    transform: rotate(180deg);
  }
  .ek-carousel-control.prev img {
    transform: rotate(0deg);
  }

  .ek-carousel-control:hover {
    opacity: 0.7;
  }

  @media (max-width: 1150px) {
    .ek-carousel-viewport {
      width: 710px; /* 2 cards */
    }
  }

  @media (max-width: 768px) {
    /* Stack section padding */
    .ek-testimonial-section {
      padding: 60px 16px;
    }

    /* Header */
    .ek-testimonial-header p {
      padding: 0;
      line-height: 1.5;
      font-size: 15px;
    }

    /* Carousel: center on screen */
    .ek-testimonial-carousel {
      margin-top: 32px;
    }

    /* Hide desktop arrows */
    .desktop-arrow {
      display: none;
    }

    /* Inner wrapper becomes a real positioned block */
    .ek-carousel-inner {
      display: block;
      position: relative;
      width: 100%;
      max-width: 325px;
      margin: 0 auto;
    }

    /* Mobile arrows — absolutely over the card */
    .mobile-arrow {
      display: flex;
      align-items: center;
      justify-content: center;
      position: absolute;
      top: 45%;
      transform: translateY(-50%);
      z-index: 10;
      background: rgba(0, 0, 0, 0.35);
      border: none;
      border-radius: 50%;
      width: 36px;
      height: 36px;
      padding: 6px;
      cursor: pointer;
      transition: background 0.2s;
    }
    .mobile-arrow:hover {
      background: rgba(0, 0, 0, 0.6);
    }
    .mobile-arrow.prev {
      left: -4px;
    }
    .mobile-arrow.next {
      right: -4px;
    }
    .mobile-arrow img {
      width: 16px;
      height: 16px;
    }
    .mobile-arrow.next img {
      transform: rotate(180deg);
    }

    /* Viewport full-width inside inner wrapper */
    .ek-carousel-viewport {
      width: 100%;
      max-width: 360px;
    }

    /* Card: fluid, full width of viewport */
    .ek-testimonial-card {
      width: 320px;
      max-width: 100%;
      height: auto;
    }

    .ek-testimonial-card img {
      height: 200px;
    }
  }
</style>

<script>
  (function () {
    function initTestimonialCarousel() {
      const track = document.querySelector(
        ".ek-carousel-track",
      ) as HTMLElement | null;
      const nextButtons = document.querySelectorAll(
        ".ek-carousel-control.next",
      ) as NodeListOf<HTMLButtonElement>;
      const prevButtons = document.querySelectorAll(
        ".ek-carousel-control.prev",
      ) as NodeListOf<HTMLButtonElement>;

      if (!track || !nextButtons.length || !prevButtons.length) return;

      let currentIndex = 0;
      const cards = document.querySelectorAll(".ek-testimonial-card");
      const totalCards = cards.length;
      if (totalCards === 0) return;

      const updateCarousel = () => {
        const cardWidth = (cards[0] as HTMLElement).offsetWidth + 25; // width + gap
        track.style.transform = `translateX(-${currentIndex * cardWidth}px)`;

        const cardsVisible =
          window.innerWidth > 1150 ? 3 : window.innerWidth > 768 ? 2 : 1;

        const atStart = currentIndex === 0;
        const atEnd = currentIndex >= totalCards - cardsVisible;

        prevButtons.forEach((btn) => {
          btn.style.opacity = atStart ? "0.3" : "1";
          btn.disabled = atStart;
        });
        nextButtons.forEach((btn) => {
          btn.style.opacity = atEnd ? "0.3" : "1";
          btn.disabled = atEnd;
        });
      };

      nextButtons.forEach((btn) =>
        btn.addEventListener("click", () => {
          const cardsVisible =
            window.innerWidth > 1150 ? 3 : window.innerWidth > 768 ? 2 : 1;
          if (currentIndex < totalCards - cardsVisible) {
            currentIndex++;
            updateCarousel();
          }
        }),
      );

      prevButtons.forEach((btn) =>
        btn.addEventListener("click", () => {
          if (currentIndex > 0) {
            currentIndex--;
            updateCarousel();
          }
        }),
      );

      window.addEventListener("resize", updateCarousel);
      setTimeout(updateCarousel, 100);
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initTestimonialCarousel);
    } else {
      initTestimonialCarousel();
    }
  })();
</script>
