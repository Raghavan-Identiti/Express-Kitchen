---
// src/components/PopularStyles.astro
import badge_price_match from "../assets/images/badge-price-match.svg";
import badge_finance from "../assets/images/badge-finance.svg";
import { Image } from "astro:assets";

import iconSaveMoney from "../assets/images/icon_save_money.svg";
import iconHassleFree from "../assets/images/icon_hassle_free.svg";
import iconCarb2 from "../assets/images/icon_carb2.svg";
import iconReady from "../assets/images/icon_ready.svg";
import iconSemiCustom from "../assets/images/icon_semi_custom.svg";
import iconTruck from "../assets/images/ek_truck_icon.svg";
import iconCart from "../assets/images/ek_shopping_cart.svg";

const popularStyles = [
  // Framed
  { img: "https://cdn11.bigcommerce.com/s-dsdbflh9ev/images/stencil/original/image-manager/avon-kitchen.jpg?t=1774707662", name: "AVON", highlight: "PAINTED WHITE", currentPrice: "3,289", currentCents: "55", oldPrice: "3,840", oldCents: "69", monthly: "50", monthlyCents: "73", leadTime: "3 Wks", desc: "Clean lines, warm feel, and priced for real life — the Avon shaker delivers without compromise.", type: "framed", link: "https://expresskitchens.com/cabinets/assembled/avon/" },
  { img: "https://cdn11.bigcommerce.com/s-dsdbflh9ev/images/stencil/original/image-manager/lexington-cabinet-kitchen.jpg?t=1774707995", name: "LEXINGTON", highlight: "PAINTED WHITE", currentPrice: "4,619", currentCents: "76", oldPrice: "5,393", oldCents: "77", monthly: "71", monthlyCents: "25", leadTime: "3 Wks", desc: "The Lexington brings timeless raised-panel character — a classic American kitchen style built to last.", type: "framed", link: "https://expresskitchens.com/cabinets/assembled/lexington/" },
  { img: "https://cdn11.bigcommerce.com/s-dsdbflh9ev/images/stencil/original/image-manager/derry-cabinet-kitchen.jpg?t=1774707987", name: "DERRY", highlight: "PAINTED STRATUS", currentPrice: "3,928", currentCents: "63", oldPrice: "4,586", oldCents: "84", monthly: "60", monthlyCents: "59", leadTime: "3 Wks", desc: "Understated craftsmanship and honest value — the Derry shaker lets the rest of your kitchen shine.", type: "framed", link: "https://expresskitchens.com/cabinets/assembled/derry/" },
  { img: "https://cdn11.bigcommerce.com/s-dsdbflh9ev/images/stencil/original/image-manager/dover-cabinet-kitchen.jpg?t=1774707989", name: "DOVER", highlight: "PAINTED WHITE", currentPrice: "3,004", currentCents: "98", oldPrice: "3,508", oldCents: "44", monthly: "46", monthlyCents: "34", leadTime: "3 Wks", desc: "The Dover offers classic shaker simplicity with a clean painted finish that never goes out of style.", type: "framed", link: "https://expresskitchens.com/cabinets/assembled/dover/" },
  { img: "https://cdn11.bigcommerce.com/s-dsdbflh9ev/images/stencil/original/image-manager/dublin-cabinet-kitchen.jpg?t=1774707992", name: "DUBLIN", highlight: "PAINTED WHITE", currentPrice: "3,928", currentCents: "63", oldPrice: "4,586", oldCents: "84", monthly: "60", monthlyCents: "59", leadTime: "3 Wks", desc: "Rich detail and solid construction — Dublin brings warmth and character to any kitchen remodel.", type: "framed", link: "https://expresskitchens.com/cabinets/assembled/dublin/" },
  { img: "https://cdn11.bigcommerce.com/s-dsdbflh9ev/images/stencil/original/image-manager/prism-barcelona-hurricane.jpg?t=1774707679", name: "PRISM", highlight: "HURRICANE", currentPrice: "4,277", currentCents: "11", oldPrice: "4,993", oldCents: "71", monthly: "65", monthlyCents: "96", leadTime: "8 Wks", desc: "The Prism Hurricane brings a bold, textured look — a standout style for kitchens that demand personality.", type: "framed", link: "https://expresskitchens.com/cabinets/assembled/prism-barcelona-hurricane/" },
  
  // Frameless
  { img: "https://cdn11.bigcommerce.com/s-dsdbflh9ev/images/stencil/original/image-manager/eden.jpg?t=1774707669", name: "EM EDEN", highlight: "GREY WOOD", currentPrice: "3,868", currentCents: "56", oldPrice: "4,835", oldCents: "70", monthly: "51", monthlyCents: "10", leadTime: "16 Wks", desc: "Where clean lines meet lasting durability — Eden sleek slab doors bring a quietly modern edge.", type: "frameless", link: "https://expresskitchens.com/cabinets/assembled/em-eden/" },
  { img: "https://cdn11.bigcommerce.com/s-dsdbflh9ev/images/stencil/original/image-manager/madison.jpg?t=1774707673", name: "EM MADISON", highlight: "SUPER WHITE", currentPrice: "3,602", currentCents: "30", oldPrice: "4,502", oldCents: "88", monthly: "47", monthlyCents: "58", leadTime: "16 Wks", desc: "Minimal and refined — the Madison slab door delivers clean lines that let your space do the talking.", type: "frameless", link: "https://expresskitchens.com/cabinets/assembled/em-madison/" },
  { img: "https://cdn11.bigcommerce.com/s-dsdbflh9ev/images/stencil/original/image-manager/manhattan-pm-pm115-carte-blanche-perfect-matte.jpg?t=1774707676", name: "EV MANHATTAN PM", highlight: "PERFECT MATTE", currentPrice: "4,258", currentCents: "43", oldPrice: "5,323", oldCents: "04", monthly: "56", monthlyCents: "25", leadTime: "16 Wks", desc: "Matte, minimal, and built to stay spotless — Manhattan slab doors are modern simplicity at its best.", type: "frameless", link: "https://expresskitchens.com/cabinets/assembled/em-manhattan-pm/" },
  { img: "https://cdn11.bigcommerce.com/s-dsdbflh9ev/images/stencil/original/image-manager/tribeca-a-l474-brushed-aluminum.jpg?t=1774707682", name: "TRIBECA A", highlight: "BRUSHED ALUMINUM", currentPrice: "3,667", currentCents: "66", oldPrice: "4,584", oldCents: "58", monthly: "48", monthlyCents: "45", leadTime: "16 Wks", desc: "Deep, textured, and built to take whatever a kitchen throws at it — a finish that feels considered.", type: "frameless", link: "https://expresskitchens.com/cabinets/assembled/tribeca-a/" },
  { img: "https://cdn11.bigcommerce.com/s-dsdbflh9ev/images/stencil/original/image-manager/tribeca-b-l591k-acacia-honey.jpg?t=1774707685", name: "TRIBECA B", highlight: "ACACIA HONEY", currentPrice: "3,728", currentCents: "48", oldPrice: "4,660", oldCents: "60", monthly: "49", monthlyCents: "25", leadTime: "16 Wks", desc: "Warm Acacia Honey tones with a bold slab profile — Tribeca B makes your kitchen the centerpiece.", type: "frameless", link: "https://expresskitchens.com/cabinets/assembled/tribeca-b/" },
  { img: "https://cdn11.bigcommerce.com/s-dsdbflh9ev/images/stencil/original/image-manager/tribeca-c-m2010y-after-hours.jpg?t=1774707688", name: "TRIBECA C", highlight: "AFTER HOURS", currentPrice: "3,791", currentCents: "45", oldPrice: "4,739", oldCents: "31", monthly: "50", monthlyCents: "08", leadTime: "16 Wks", desc: "Dark, dramatic After Hours finish — Tribeca C is for kitchens that refuse to blend into the background.", type: "frameless", link: "https://expresskitchens.com/cabinets/assembled/tribeca-c/" }
];

const features = [
  { icon: iconSaveMoney, label: "Save Money" },
  { icon: iconHassleFree, label: "Hassle-Free" },
  { icon: iconCarb2, label: "Carb2 Compliant" },
  { icon: iconReady, label: "Ready to Install" },
  { icon: iconSemiCustom, label: "Semi-Custom" }
];
---

<section class="ek-popular-section" id="productSection">
  <div class="container ek-popular-container">
    
    <!-- Header -->
    <div class="ek-popular-header text-center">
      <span class="ek-tagline-cream">MOST POPULAR STYLES</span>
      <h2 class="ek-section-title">
        Find the <span class="ek-text-red">one that feels like yours.</span>
      </h2>
      <p class="ek-popular-subtitle">
        From framed classics to clean frameless designs,<br/>
        Shop assembled cabinet styles our customers love most right now.
      </p>
      <p class="ek-popular-highlight-text">
        Each cabinet features soft-close doors and drawers, customizable storage
      </p>
      
      <div class="ek-header-badges">
        <Image src={badge_price_match} alt="Price Match Guarantee" class="ek-badge-img" loading="lazy" />
        <Image src={badge_finance} alt="0% APR Finance" class="ek-badge-img" loading="lazy" />
      </div>
    </div>

    <!-- Filters Row -->
    <div class="ek-filters-wrap d-flex flex-wrap align-items-center justify-content-center gap-3 gap-lg-4 mb-5">
      <!-- Framed/Frameless Toggle -->
      <div class="ek-type-toggle" id="style-filter-toggle">
        <button class="ek-toggle-btn active" data-filter="framed">Framed</button>
        <button class="ek-toggle-btn" data-filter="frameless">Frameless</button>
      </div>
      
      <!-- Color Swatches -->
      <div class="ek-color-swatches d-flex gap-2 align-items-center">
        <div class="ek-swatch" style="background-color: #e8eceb;"></div>
        <div class="ek-swatch" style="background-color: #ffffff; border: 1px solid #e0e0e0;"></div>
        <div class="ek-swatch" style="background-color: #d1b46a;"></div>
        <div class="ek-swatch" style="background-color: #bfa18f;"></div>
        <div class="ek-swatch" style="background-color: #8c3b1a;"></div>
        <div class="ek-swatch" style="background-color: #838d83;"></div>
      </div>

      <!-- Feature Tags -->
      <div class="ek-feature-list d-flex flex-wrap gap-3 align-items-center">
        {features.map(f => (
          <div class="ek-feature-item">
            <Image src={f.icon} alt={f.label} width={16} height={16} style="width:16px; height:16px; margin-right:10px;" loading="lazy" />
            <span>{f.label}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Products Grid -->
    <div class="row g-5 ek-products-row" id="popular-styles-grid">
      {popularStyles.map((product) => (
        <div class="col-lg-4 col-md-6 col-12 style-grid-item" data-category={product.type}>
          <div class="ek-product-card">
            <!-- Image -->
            <div class="ek-product-img-wrap">
              <Image src={product.img} alt={product.name} class="ek-product-img" width={400} height={300} loading="lazy" />
              {/* <span class="ek-style-badge">{product.type}</span> */}
            </div>
            
            <!-- Details -->
            <div class="ek-product-details">
              <h3 class="ek-product-title">{product.name} <span class="ek-text-red">{product.highlight}</span></h3>
              
              <div class="ek-price-grid">
                <!-- Prices -->
                <div class="ek-price-block ek-price-primary">
                  <div class="ek-price-current">
                    <span class="currency">$</span>
                    <span class="dollars">{product.currentPrice}</span>
                    <span class="cents">{product.currentCents}</span>
                  </div>
                  <div class="ek-price-old">
                    <span class="currency">$</span>
                    <span class="dollars">{product.oldPrice}</span>
                    <span class="cents">{product.oldCents}</span>
                  </div>
                </div>
                
                <!-- Monthly Price -->
                <div class="ek-price-block ek-price-monthly">
                  <div class="as-low">As Low As</div>
                  <div class="monthly-val">
                    <span class="currency-small">$</span>
                    <span class="dollars-small">{product.monthly}</span>
                    <span class="cents-small">{product.monthlyCents}</span>
                    <span class="per-month">/Month</span>
                  </div>
                </div>
                
                <!-- Lead Time -->
                <div class="ek-price-block ek-price-lead">
                  <Image src={iconTruck} alt="Delivery" class="truck-icon" width={24} height={24} loading="lazy" />
                  <span>{product.leadTime}</span>
                </div>
              </div>

              <p class="ek-product-desc">{product.desc}</p>
              
              <a href={product.link} target="_blank" rel="noopener noreferrer" class="ek-btn-shop">
                <Image src={iconCart} alt="Cart" class="cart-icon" width={18} height={18} loading="lazy" /> 
                Shop Now
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Footer Note -->
    <div class="ek-popular-footer mt-5 text-start">
      <p>*Note: Based on a standard 10x10 kitchen. Price reflects a fixed cabinet selection - contact us to build a custom configuration.</p>
    </div>

  </div>
</section>

<style>
  .ek-popular-section {
    padding: 80px 0;
    background-color: var(--ek-white);
    font-family: var(--ek-primary-font);
  }

  .ek-popular-container {
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* Header */
  .ek-popular-header {
    margin-bottom: 40px;
  }

  .ek-tagline-cream {
    display: inline-block;
    background-color: var(--ek-soft-cream);
    color: var(--ek-gray-tint-25);
    padding: 6px 16px;
    border-radius: 20px;
    font-size: 13px;
    font-weight: 500;
    line-height: 100%;
    letter-spacing: 0%;
    text-transform: uppercase;
    margin-bottom: 20px;
  }

  .ek-section-title {
    font-size: 35px;
    font-weight: 700;
    letter-spacing: 0%;
    line-height: 120%;
    color: var(--ek-heading-color);
    margin-bottom: 20px;
  }

  .ek-text-red {
    color: var(--ek-primary-red);
  }

  .ek-popular-subtitle {
    font-size: 18px;
    font-weight: 400;
    line-height: 100%;
    letter-spacing: 0%  ;
    color: var(--ek-gray-tint-40);
    margin-bottom: 15px;
  }

  .ek-popular-highlight-text {
    font-size: 16px;
    font-weight: 400;
    line-height: 100%;
    letter-spacing: 0%;
    color: var(--ek-red-tint-40);
    margin-bottom: 20px;
  }

  .ek-header-badges {
    display: flex;
    justify-content: center;
    gap: 10px;
  }
  
  .ek-badge-img {
    height: 50px;
    width: auto;
  }

  /* Filters Row */
  .ek-filters-wrap {
    border-radius: 100px;
    padding: 10px 20px;
  }

  .ek-type-toggle {
    display: flex;
    background: var(--ek-white);
    border-radius: 30px;
    padding: 8px 20px;
    background-color: #FFF9F9;
    overflow: hidden;
  }

  .ek-toggle-btn {
    border: none;
    background: transparent;
    padding: 8px 20px;
    font-size: 16px;
    font-weight: 500;
    line-height: 100%;
    letter-spacing: -2%;
    color: var(--ek-gray-tint-40);
    transition: all 0.2s;''
  }

  .ek-toggle-btn.active {
    background: #fff;
    color: var(--ek-gray-tint-25);
    border: 1px solid var(--ek-red-tint-10);
    border-radius: 30px;
    box-shadow: 0px 4.63px 28.95px 0px #0000001F;

  }

  .ek-color-swatches {
    display: flex;
    gap: 10px;
    background-color: #FFF9F9;
    padding: 8px 20px;
    border-radius: 30px;
  }

  .ek-swatch {
    width: 24px;
    height: 24px;
    border-radius: 50%;
  }

  .ek-feature-list {
    display: flex;
    gap: 10px;
    background-color: #fff;
    border: 1px solid var(--ek-red-tint-80);
    padding: 8px 20px;
    border-radius: 30px;
  }

  .ek-feature-item {
    display: flex;
    align-items: center;
    font-size: 13px;
    font-weight: 500;
    color: var(--ek-gray-tint-40);
  }

  /* Product Cards */
  .ek-product-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    background: var(--ek-white);
  }

  .ek-product-img-wrap {
    width: 100%;
    aspect-ratio: 4/3;
    overflow: hidden;
    margin-bottom: 15px;
    background: #f5f5f5; 
    position: relative;
  }

  .ek-style-badge {
    position: absolute;
    top: 15px;
    right: 15px;
    background-color: var(--ek-white);
    color: var(--ek-primary-red);
    font-size: 11px;
    font-weight: 700;
    padding: 6px 12px;
    border-radius: 20px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
    z-index: 5;
  }

  .ek-product-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  
  .ek-product-card:hover .ek-product-img {
    transform: scale(1.03);
  }

  .ek-product-details {
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .ek-product-title {
    font-size: 23px;
    font-weight: 700;
    line-height: 100%;
    letter-spacing:0%;
    color: var(--ek-heading-color);
    margin: 15px 0px 25px;
    text-transform: uppercase;
  }

  /* Price Grid */
  .ek-price-grid {
    display: flex;
    align-items: stretch;
    border: 1px solid var(--ek-red-tint-60);
    background-color: #FDF8F8;
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 20px;
    width: fit-content;
  }

  .ek-price-block {
    padding: 8px 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-right: 1px solid var(--ek-red-tint-60);
  }
  .ek-price-block:last-child {
    border-right: none;
  }

  /* Primary Prices (Current + Old) */
  .ek-price-primary {
    display: flex;
    gap: 10px;
    align-items: center;
    padding: 8px 13px;
  }

  .ek-price-current {
    color: var(--ek-primary-red);
    font-weight: 800;
    display: flex;
    align-items: flex-start;
  }
  .ek-price-current .currency { font-size: 14px; margin-top: -2px; font-weight: 700; color: var(--ek-primary-red); }
  .ek-price-current .dollars { font-size: 24px; line-height: 1; font-weight: 700; letter-spacing: 0px; color: var(--ek-primary-red); }
  .ek-price-current .cents { font-size: 16px; margin-top: -3px; font-weight: 700; color: var(--ek-primary-red); }

  .ek-price-old {
    color: #D4D4D4;
    font-weight: 400;
    display: flex;
    align-items: flex-start;
    margin-top: 6px;
  }
  .ek-price-old .currency { font-size: 12px; margin-top: -2px; color: #D4D4D4; }
  .ek-price-old .dollars {
    font-size: 18px;
    line-height: 1;
    letter-spacing: 0px;
    color: #D4D4D4;
    text-decoration: line-through;
    text-decoration-thickness: 1.2px;
  }
  .ek-price-old .cents { font-size: 12px; margin-top: -2px; color: #D4D4D4; }

  /* Monthly Price */
  .ek-price-monthly {
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 6px 16px;
  }
  .ek-price-monthly .as-low {
    color: var(--ek-red-tint-40);
    font-size: 11px;
    font-weight: 500;
    line-height: 1.2;
    margin-bottom: 2px;
  }
  .monthly-val {
    color: var(--ek-red-tint-40);
    display: flex;
    align-items: flex-start;
  }
  .monthly-val .currency-small { font-size: 10px; margin-top: -2px; color: var(--ek-red-tint-40); }
  .monthly-val .dollars-small { font-size: 11px; font-weight: 500; line-height: 1; color: var(--ek-red-tint-40); }
  .monthly-val .cents-small { font-size: 8px; font-weight: 500; margin-top: -3px; color: var(--ek-red-tint-40); }
  .monthly-val .per-month { font-size: 11px; font-weight: 400; margin-left: 0px; align-self: flex-end; line-height: 1; color: var(--ek-red-tint-40); }

  /* Lead Time */
  .ek-price-lead {
    color: var(--ek-gray-tint-25);
    font-size: 13px;
    font-weight: 500;
    line-height: 150%;
    letter-spacing: 0%;
    display: flex;
    align-items: center;
    gap: 6px;
    /* padding: 8px 16px; */
  }
  .truck-icon {
    width: 24px;
    height: auto;
  }

  /* Description */
  .ek-product-desc {
    font-size: 14px;
    line-height: 150%;
    letter-spacing: 0%;
    color: var(--ek-gray-tint-40);
    margin-bottom: 25px;
    flex-grow: 1;
  }

  /* Shop Button */
  .ek-btn-shop {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background-color: var(--ek-red-shade-60); /* Deep maroon */
    color: var(--ek-white);
    font-family: var(--ek-primary-font);
    font-size: 18px;
    font-weight: 500;
    padding: 12px 24px;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    transition: background-color 0.2s, color 0.2s;
    width: 160px;
    text-decoration: none;
  }
  
  .ek-btn-shop:hover {
    background-color: var(--ek-primary-red);
    color: var(--ek-white);
    text-decoration: none;
  }

  .cart-icon {
    width: 18px;
    height: auto;
  }

  /* Footer Note */
  .ek-popular-footer p {
    font-size: 12px;
    color: var(--ek-gray-tint-40);
    margin: 0;
  }

  /* Responsive Adjustments */
  @media (max-width: 1399px) {
    .ek-price-grid {
      flex-wrap: wrap;
      justify-content: center;
      border-radius: 12px;
      width: 100%;
    }
    .ek-price-block {
      border-right: none;
      border-bottom: 1px solid var(--ek-red-tint-40);
      width: 100%;
    }
    .ek-price-block:last-child {
      border-bottom: none;
    }
    .ek-price-primary {
      justify-content: center;
    }
  }

  @media (max-width: 991px) {
    .ek-section-title {
      font-size: 30px;
    }
    .ek-filters-wrap {
      flex-direction: column;
      border-radius: 12px;
      padding: 20px;
    }
    .ek-feature-list {
      margin-left: 0;
      justify-content: center;
    }
  }
  @media (max-width: 767px){
    .ek-product-title {
      font-size: 20px;
      text-align: center;
    }
    .ek-popular-footer p{
      text-align: center;
    }
    .ek-price-grid {
      flex-direction: column;
      border-radius: 12px;
      padding: 0px;
    }
    .ek-price-block {
      border-right: none;
      border-bottom: 1px solid var(--ek-red-tint-40);
      width: 100%;
    }
    .ek-price-block:last-child {
      border-bottom: none;
    }
    .ek-price-primary {
      justify-content: center;
    }
    .ek-product-desc {
      text-align: center;
    }
    .ek-btn-shop {
      margin-left: auto;
      margin-right: auto;
    }
    
    .ek-popular-subtitle,.ek-popular-highlight-text{
      line-height: 130%;
      padding: 0 1rem;
    }
  }


  
</style>

<script>
  function initStyleFiltering() {
    const filterButtons = document.querySelectorAll('#style-filter-toggle .ek-toggle-btn');
    const styleItems = document.querySelectorAll('.style-grid-item');

    filterButtons.forEach(button => {
      button.addEventListener('click', () => {
        const filter = button.getAttribute('data-filter');

        // Toggle active button
        filterButtons.forEach(btn => btn.classList.remove('active'));
        button.classList.add('active');

        // Filter items
        styleItems.forEach(item => {
          const category = item.getAttribute('data-category');
          const isMatch = filter === 'all' || filter === category;
          
          if (isMatch) {
            // Show new items
            (item as HTMLElement).style.display = 'block';
            // Trigger reflow to ensure transition plays
            void (item as HTMLElement).offsetHeight; 
            item.classList.remove('filtered-out');
          } else {
            // Hide old items
            item.classList.add('filtered-out');
            setTimeout(() => {
               if(item.classList.contains('filtered-out')) {
                  (item as HTMLElement).style.display = 'none';
               }
            }, 200); // Matches the updated 0.2s transition
          }
        });
      });
    });
  }

  // Run on mount
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      initStyleFiltering();
      document.querySelector<HTMLElement>('#style-filter-toggle .ek-toggle-btn.active')?.click();
    });
  } else {
    initStyleFiltering();
    document.querySelector<HTMLElement>('#style-filter-toggle .ek-toggle-btn.active')?.click();
  }
</script>
